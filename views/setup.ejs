<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Synnabot — Setup Guide</title>
  <meta name="description" content="Step-by-step guide to set up and self-host Synnabot, your AI-powered Discord bot with moderation, timezone, and Twitch integration.">
  <meta name="theme-color" content="#fbbf24">
  <link rel="icon" type="image/png" href="/assets/icon.png">
  <meta property="og:type" content="website">
  <meta property="og:locale" content="en_US">
  <meta property="og:site_name" content="Synnabot">
  <meta property="og:title" content="Synnabot — Setup Guide">
  <meta property="og:description" content="Step-by-step guide to set up and self-host Synnabot, your AI-powered Discord bot with moderation, timezone, and Twitch integration.">
  <meta property="og:url" content="<%= baseUrl %>/setup">
  <meta property="og:image" content="<%= baseUrl %>/assets/icon.png">
  <meta property="og:image:type" content="image/png">
  <meta property="og:image:width" content="512">
  <meta property="og:image:height" content="512">
  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Synnabot — Setup Guide">
  <meta name="twitter:description" content="Step-by-step guide to set up and self-host Synnabot, your AI-powered Discord bot with moderation, timezone, and Twitch integration.">
  <meta name="twitter:image" content="<%= baseUrl %>/assets/icon.png">
  <link rel="stylesheet" href="/styles.css" />
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
</head>
<body>
  <nav class="navbar motion-hide">
    <a href="/" class="nav-brand">
      <img src="/assets/icon.png" alt="Synnabot Logo">
      <span>Synnabot</span>
    </a>
    
    <button class="menu-toggle" id="menuToggle">
      <i class="ph ph-list"></i>
    </button>

    <div class="nav-links">
      <a href="/" class="nav-item"><i class="ph ph-house"></i> Home</a>
      <a href="/docs" class="nav-item"><i class="ph ph-list-dashes"></i> Commands</a>
      <a href="/setup" class="nav-item active"><i class="ph ph-wrench"></i> Setup</a>
    </div>
  </nav>

  <div class="drawer-overlay" id="drawerOverlay"></div>
  <div class="nav-drawer" id="navDrawer">
    <a href="/" class="nav-item"><i class="ph ph-house"></i> Home</a>
    <a href="/docs" class="nav-item"><i class="ph ph-list-dashes"></i> Commands</a>
    <a href="/setup" class="nav-item active"><i class="ph ph-wrench"></i> Setup</a>
  </div>

  <div class="container">
    <header class="motion-hide">
      <h1>Set Up Synnabot Locally</h1>
      <p class="subtitle">Host your own AI-powered Discord assistant in just a few steps.</p>
    </header>

    <main class="setup-steps">
      <section class="bento-card motion-hide step-card" style="opacity: 0;">
        <h2><i class="ph ph-list-checks"></i> Prerequisites</h2>
        <ul>
          <li><a href="https://nodejs.org/en/download" target="_blank">Node.js v18 or above</a></li>
          <li><a href="https://discord.com/developers/applications" target="_blank">Discord Developer Account</a></li>
          <li><a href="https://dev.twitch.tv/console/apps" target="_blank">Twitch Developer App</a></li>
          <li><a href="https://www.mongodb.com/cloud/atlas/register" target="_blank">MongoDB Atlas Account</a></li>
          <li><a href="https://console.cloud.google.com/apis" target="_blank">Google Cloud API Key</a></li>
        </ul>
      </section>

      <section class="bento-card motion-hide step-card" style="opacity: 0;">
        <h2><i class="ph ph-git-branch"></i> Step 1: Clone the Repository</h2>
        <pre><code>git clone https://github.com/YOUR_USERNAME/synnabot.git
cd synnabot
npm install</code></pre>
        <p style="color: var(--subtext); font-size: 0.95rem;">This installs all required dependencies listed in <code>package.json</code>.</p>
      </section>

      <section class="bento-card motion-hide step-card" style="opacity: 0;">
        <h2><i class="ph ph-file-code"></i> Step 2: Configure Environment Variables</h2>
        <p style="color: var(--subtext); font-size: 0.95rem;">Create the following <strong>.env</strong> files and add your credentials:</p>

        <h3><code>/.env</code></h3>
        <pre><code>DISCORD_BOT_TOKEN=
CLIENT_ID=
GUILD_ID=
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_CLUSTER=
MONGO_DATABASE=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
GOOGLE_API=</code></pre>

        <h3><code>/utils/discord/.env</code></h3>
        <pre><code>DISCORD_BOT_TOKEN=
CLIENT_ID=
DISCORD_GUILD_ID=
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
GOOGLE_API=</code></pre>

        <h3><code>/DB/.env</code></h3>
        <pre><code>CLIENT_ID=
MONGO_USERNAME=
MONGO_PASSWORD=
MONGO_CLUSTER=
MONGO_DATABASE=</code></pre>

        <p class="note"><i class="ph ph-info"></i> You can reuse the same values across the different files where applicable.</p>
      </section>

      <section class="bento-card motion-hide step-card" style="opacity: 0;">
        <h2><i class="ph ph-cloud-arrow-up"></i> Step 3: Set Up External Services</h2>

        <h3>Discord Developer Portal</h3>
        <ul>
          <li>Create a new application at <a href="https://discord.com/developers/applications" target="_blank">Discord Developer Portal</a></li>
          <li>Under the "Bot" tab, add a bot and copy the token into <code>DISCORD_BOT_TOKEN</code>.</li>
          <li>Under the "OAuth2" tab, copy your <code>CLIENT_ID</code>.</li>
        </ul>

        <h3>Twitch Developer Console</h3>
        <ul>
          <li>Visit the <a href="https://dev.twitch.tv/console/apps" target="_blank">Twitch Developer Console</a></li>
          <li>Create an app and copy your <code>Client ID</code> and <code>Client Secret</code>.</li>
        </ul>

        <h3>MongoDB Atlas</h3>
        <ul>
          <li>Register at <a href="https://www.mongodb.com/cloud/atlas/register" target="_blank">MongoDB Atlas</a></li>
          <li>Create a cluster and a database user. Use these credentials in your .env files.</li>
        </ul>

        <h3>Google Cloud Platform</h3>
        <ul>
          <li>Open the <a href="https://console.cloud.google.com/apis" target="_blank">Google Cloud Console</a></li>
          <li>Enable the Gemini AI / Generative Language API.</li>
          <li>Generate and copy your API key for use in the <code>GOOGLE_API</code> variable.</li>
        </ul>
      </section>

      <section class="bento-card motion-hide step-card" style="opacity: 0;">
        <h2><i class="ph ph-play-circle"></i> Step 4: Run the Bot</h2>
        <pre><code>node index.mjs</code></pre>
        <p style="color: var(--subtext); font-size: 0.95rem;">If configured correctly, Synnabot will connect to Discord, MongoDB, and Twitch.</p>
      </section>

      <section class="buttons motion-hide" style="opacity: 0;">
        <a href="/" class="button secondary"><i class="ph ph-arrow-left"></i> Back to Home</a>
        <a href="https://github.com/Azaken1248/synnabot" target="_blank" class="button"><i class="ph ph-github-logo"></i> View on GitHub</a>
      </section>
    </main>

    <footer class="motion-hide" style="opacity: 0;">
      <p>&copy; <%= new Date().getFullYear() %> Synnabot | Built by Azaken</p>
    </footer>
  </div>

  <script type="module">
    import { animate, inView, stagger } from "https://esm.sh/framer-motion";

    animate(".navbar", { opacity: [0, 1], y: [-20, 0] }, { duration: 0.6, easing: "easeOut" });
    animate("header", { opacity: [0, 1], y: [30, 0] }, { duration: 0.8, delay: 0.2, easing: "easeOut" });

    const menuToggle = document.getElementById('menuToggle');
    const navDrawer = document.getElementById('navDrawer');
    const drawerOverlay = document.getElementById('drawerOverlay');

    function toggleDrawer() {
      navDrawer.classList.toggle('open');
      drawerOverlay.classList.toggle('open');
    }

    menuToggle.addEventListener('click', toggleDrawer);
    drawerOverlay.addEventListener('click', toggleDrawer);

    inView(".setup-steps", () => {
      animate(".step-card", { opacity: [0, 1], y: [30, 0] }, { delay: stagger(0.15, { startDelay: 0.2 }), duration: 0.6, easing: "easeOut" });
    });

    inView(".buttons", (el) => {
        animate(el, { opacity: [0, 1], y: [20, 0] }, { duration: 0.6, delay: 0.4 });
    });

    inView("footer", (el) => {
        animate(el, { opacity: [0, 1], y: [20, 0] }, { duration: 0.6 });
    });
  </script>
</body>
</html>
